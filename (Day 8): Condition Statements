#nested if: if inside the another if is called as nested if
'''
rama_SBI_details = {"ATM PIN":'5002'}
pin_ = input("Enter your 4  digit ATM PIN:")
if len(pin_) == 4:
    if pin_ in rama_SBI_details["ATM PIN"]:
        print("Welcome to SBI ATM")
    else:
        print("You have entered incorrect pin")
else:
    print("pls entered only 4 digit pin") 

