#vowels and consontant using if conditions in given 

text = input("Enter a string: ")
vowels = 0
consonants = 0
for ch in text:
    ch = ch.lower()
    if ch == 'a' or ch == 'e' or ch == 'i' or ch == 'o' or ch == 'u':
        vowels += 1
    elif ch >= 'a' and ch <= 'z':
        consonants += 1
print("Number of vowels:", vowels)
print("Number of consonants:", consonants)

















































































